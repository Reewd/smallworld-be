PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/smallworld?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Google Maps Routes API
# When set, the backend uses Google Routes instead of the local haversine fallback.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Auth
# Your current Firebase project.
FIREBASE_PROJECT_ID=smallworld-a0223

# Production / non-emulator mode:
# point this at your backend Firebase service account JSON file.
FIREBASE_CREDENTIALS_FILE=/absolute/path/to/firebase-service-account.json

# Local development with Firebase Auth emulator:
# when set, the backend verifies emulator-issued Firebase ID tokens
# instead of using production credentials.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# App environment. Used to choose default log formatting.
# Common values: local, dev, production
APP_ENV=local

# Structured logging
# LOG_FORMAT supports: text, json
# LOG_LEVEL supports: debug, info, warn, error
LOG_FORMAT=text
LOG_LEVEL=info

# PostgreSQL query tracing
# Slow queries at or above this threshold are logged.
DB_LOG_SLOW_QUERY_MS=250

# When true, all successful queries are logged at debug level.
# Query arguments are still not logged.
DB_LOG_ALL_QUERIES=false
